rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // Products: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Orders: Public create/get for confirmation page, Admin list/write/delete
    match /orders/{orderId} {
      allow create: if true;
      allow get: if true;
      allow list, update, delete: if isAuthenticated();
    }

    // Counters: Public read/write (untuk order number generator)
    match /counters/{counterId} {
      allow read, write: if true;
    }

    // Customers: Public create/update (untuk upsert saat order), Admin read/delete
    match /customers/{customerId} {
      allow create, update: if true;
      allow read, delete: if isAuthenticated();
    }

    // Payment Config: Public read, Admin write
    match /paymentConfig/{configId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Settings: Public read for customer-facing business info, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
